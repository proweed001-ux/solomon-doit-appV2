{
  "name": "solomon-doit-appv2",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host=0.0.0.0 --port=3000",
    "clean": "rimraf dist",
    "smoke": "node scripts/smoke-check.mjs",
    "verify": "npm run smoke",
    "verify:react": "npm run build && npm run smoke",
    "test:pro-lazy": "node scripts/test-pro-telesale-pagination.mjs",
    "test:fuel-warning": "node scripts/test-fuel-warning.mjs",
    "test:local-xlsx": "node scripts/test-local-xlsx.mjs",
    "test:admin-storage": "node scripts/test-admin-storage-guards.mjs",
    "test:promo-packing": "node scripts/test-promo-packing-master.mjs",
    "test:promo-function-sync": "node scripts/test-promo-function-sync.mjs",
    "test:promo-latest": "node scripts/test-promo-latest-only.mjs",
    "test:promo-dynamic": "node scripts/test-promo-dynamic-grid-price-safety.mjs",
    "test:promo-master": "node scripts/test-promo-master-consensus.mjs",
    "test:promo-runtime": "node scripts/test-promo-runtime-release-gate.mjs",
    "test:promo-safe": "npm run test:promo-dynamic && npm run test:promo-master && npm run test:promo-runtime && npm run test:promo-latest",
    "check:doit": "node scripts/check-doit.mjs \"../Daily_DOIT_Template_V1.4 2026-05 - AYA (4).xlsx\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^6.2.3",
    "typescript": "~5.8.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "xlsx": "^0.18.5",
    "lucide-react": "^0.546.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "tsx": "^4.21.0"
  }
}